# Weather Trading Bot Configuration

# ==============================================
# POLYMARKET CLOB API CREDENTIALS
# ==============================================
CLOB_PRIVATE_KEY=0x...
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ==============================================
# TRADING CONFIGURATION
# ==============================================
DRY_RUN=true
BANKROLL_USDC=40
MAX_POSITION_USDC=2
MIN_POSITION_USDC=1
EDGE_MINIMUM=0.25
MAX_POSITIONS_COUNT=15
COPY_RATIO=0.05

# ==============================================
# DATA STORAGE
# ==============================================
DATA_DIR=/home/bot/weather-bot/data

# ==============================================
# NOTIFICATIONS
# ==============================================
NOTIFY_SLACK=false
SLACK_WEBHOOK_URL=
NOTIFY_ON_TRADE_COPIED=true
NOTIFY_ON_POSITION_UPDATE=true
NOTIFY_ON_BOT_STARTED=true