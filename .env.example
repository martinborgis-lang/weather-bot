# Configuration du Weather Trading Bot Polymarket

# ==============================================
# TRADING CONFIGURATION - MODE LIVE
# ==============================================
DRY_RUN=true
BANKROLL_USDC=40
MAX_POSITION_SIZE_USDC=2
MIN_POSITION_SIZE_USDC=1
COPY_RATIO=0.05
EDGE_MINIMUM=0.25
MAX_POSITIONS_COUNT=15
KELLY_MULTIPLIER=0.25

# ==============================================
# DATA DIRECTORY
# ==============================================
DATA_DIR=./data

# ==============================================
# OPEN-METEO PROFESSIONAL API
# ==============================================
OPENMETEO_API_KEY=your_api_key_here

# ==============================================
# POLYMARKET CLOB API CREDENTIALS
# ==============================================
CLOB_API_KEY=your_clob_api_key
CLOB_SECRET=your_clob_secret
CLOB_PASSPHRASE=your_clob_passphrase
CLOB_PRIVATE_KEY=your_private_key

# ==============================================
# AGENT INTERVALS (SECONDS)
# ==============================================
SCANNER_INTERVAL=300
FORECASTER_INTERVAL=300
EDGE_DETECTOR_INTERVAL=180
POSITION_MANAGER_INTERVAL=60
TRADE_EXECUTOR_INTERVAL=30

# ==============================================
# STREAMLIT DASHBOARD
# ==============================================
PORT=8080

# ==============================================
# API RATE LIMITING
# ==============================================
RATE_LIMIT_DELAY=0.2
CACHE_TTL_SECONDS=900

# ==============================================
# NOTIFICATIONS (OPTIONAL)
# ==============================================
SLACK_WEBHOOK_URL=your_slack_webhook_url

# ==============================================
# ADVANCED TRADING SETTINGS
# ==============================================
# Liquidité minimum des marchés (en USDC)
MIN_LIQUIDITY=10000

# Prix d'entrée maximum pour YES
MAX_ENTRY_PRICE=0.30

# Prix minimum pour NO
MIN_EXIT_PRICE_NO=0.45

# Seuil take profit partiel (en decimal: 0.40 = 40%)
TAKE_PROFIT_PARTIAL_PCT=0.40