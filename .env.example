# Configuration du Weather Trading Bot Polymarket

# ==============================================
# TRADING CONFIGURATION
# ==============================================
DRY_RUN=true
BANKROLL_USDC=250
MAX_POSITION_USDC=10
# ==============================================
# POLYMARKET CLOB API CREDENTIALS
# ==============================================
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=
CLOB_PRIVATE_KEY=
# ==============================================
# NOTIFICATIONS (OPTIONAL)
# ==============================================
NOTIFY_SLACK=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
NOTIFY_ON_TRADE_COPIED=true
NOTIFY_ON_POSITION_UPDATE=true

# ==============================================
# ADVANCED SETTINGS (OPTIONAL)
# ==============================================
# Edge minimum requis (en decimal: 0.20 = 20%)
EDGE_MINIMUM=0.20

# Seuil take profit partiel (en decimal: 0.40 = 40%)
TAKE_PROFIT_PARTIAL_PCT=0.40

# Pourcentage max du capital par position (en decimal: 0.02 = 2%)
MAX_POSITION_PCT=0.02

# Liquidité minimum des marchés (en USDC)
MIN_LIQUIDITY=10000

# Prix d'entrée maximum pour YES
MAX_ENTRY_PRICE=0.30

# Prix minimum pour NO
MIN_EXIT_PRICE_NO=0.45